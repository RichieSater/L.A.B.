{
  "rewrites": [
    { "source": "/api/compass-sessions/:id", "destination": "/api/compass-sessions/[id]?id=:id" },
    { "source": "/api/scheduled-sessions/:id", "destination": "/api/scheduled-sessions/[id]?id=:id" },
    { "source": "/api/:path*", "destination": "/api/:path*" },
    { "source": "/:path*", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/((?!assets/).*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-store, max-age=0, must-revalidate" }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ]
}
